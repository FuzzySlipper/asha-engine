{
  "schemaVersion": 3,
  "distribution": {
    "kind": "git-workspace",
    "repository": "https://github.com/FuzzySlipper/asha-engine.git",
    "workspaceManifest": "public-rust/Cargo.toml",
    "compatibilityMarker": "public-rust.v1",
    "versionRequirement": "^0.1",
    "pinKind": "exact-revision",
    "developmentPathRoot": "../asha-engine/public-rust"
  },
  "consumerPolicies": [
    {
      "consumerRole": "asha-demo",
      "preferredCrates": [
        "asha-gameplay-module-conformance",
        "asha-gameplay-module-sdk",
        "asha-native-runtime-provider",
        "asha-runtime-session-composition"
      ],
      "quarantinedCrates": [
        "asha-game-rule-extension",
        "asha-gameplay-runtime-host"
      ],
      "developmentPreferredDependencyPaths": [
        "../asha-engine/public-rust/gameplay-module-conformance",
        "../asha-engine/public-rust/gameplay-module-sdk",
        "../asha-engine/public-rust/native-runtime-provider",
        "../asha-engine/public-rust/runtime-session-composition"
      ],
      "developmentQuarantinedDependencyPaths": [
        "../asha-engine/public-rust/game-rule-extension",
        "../asha-engine/public-rust/gameplay-runtime-host"
      ],
      "forbiddenPathPatterns": [
        "engine-rs/crates/*"
      ]
    },
    {
      "consumerRole": "asha-testing",
      "preferredCrates": [
        "asha-gameplay-module-conformance",
        "asha-gameplay-module-sdk",
        "asha-native-runtime-provider",
        "asha-runtime-session-composition"
      ],
      "quarantinedCrates": [
        "asha-gameplay-runtime-host"
      ],
      "developmentPreferredDependencyPaths": [
        "../asha-engine/public-rust/gameplay-module-conformance",
        "../asha-engine/public-rust/gameplay-module-sdk",
        "../asha-engine/public-rust/native-runtime-provider",
        "../asha-engine/public-rust/runtime-session-composition"
      ],
      "developmentQuarantinedDependencyPaths": [
        "../asha-engine/public-rust/gameplay-runtime-host"
      ],
      "forbiddenPathPatterns": [
        "engine-rs/crates/*"
      ]
    },
    {
      "consumerRole": "asha-rulebench",
      "preferredCrates": [
        "asha-gameplay-module-conformance",
        "asha-gameplay-module-sdk",
        "asha-native-runtime-provider",
        "asha-runtime-session-composition"
      ],
      "quarantinedCrates": [
        "asha-gameplay-runtime-host"
      ],
      "developmentPreferredDependencyPaths": [
        "../asha-engine/public-rust/gameplay-module-conformance",
        "../asha-engine/public-rust/gameplay-module-sdk",
        "../asha-engine/public-rust/native-runtime-provider",
        "../asha-engine/public-rust/runtime-session-composition"
      ],
      "developmentQuarantinedDependencyPaths": [
        "../asha-engine/public-rust/gameplay-runtime-host"
      ],
      "forbiddenPathPatterns": [
        "engine-rs/crates/*"
      ]
    }
  ],
  "crates": [
    {
      "crate": "asha-game-rule-extension",
      "status": "public",
      "disposition": "quarantined",
      "compatibilityEntry": "legacy-weapon-effect-hook",
      "facadePath": "public-rust/game-rule-extension",
      "sourceOfTruth": "engine-rs/crates/rules/game-rule-extension",
      "intendedConsumerRole": "Public Rust trait and DTO facade for downstream ASHA Game Project rule modules.",
      "allowedConsumerRoles": [
        "asha-demo"
      ],
      "dependencyForm": {
        "kind": "git",
        "versionRequirement": "^0.1",
        "example": "asha-game-rule-extension = { git = \"https://github.com/FuzzySlipper/asha-engine.git\", rev = \"<40-char-commit>\", version = \"^0.1\" }",
        "developmentExample": "asha-game-rule-extension = { path = \"../asha-engine/public-rust/game-rule-extension\" }"
      },
      "exposes": [
        "GameRuleModule",
        "GAME_RULE_EXTENSION_COMPATIBILITY_DIAGNOSTIC",
        "GameRuleExtensionResult",
        "GameRuleModuleManifest",
        "GameRuleModuleRef",
        "GameRuleHookDeclaration",
        "GameExtensionHookKind",
        "WeaponEffectHookRequest",
        "GameExtensionProposal",
        "GameExtensionHookReceipt",
        "GameExtensionReplayEvidence"
      ],
      "requiredExposes": [
        "GameRuleModule",
        "WeaponEffectHookRequest",
        "GameExtensionProposal"
      ],
      "changelog": "docs/consumer-compatibility.md#rust-game-rule-extension-compatibility-log"
    },
    {
      "crate": "asha-gameplay-module-conformance",
      "status": "public",
      "disposition": "preferred",
      "facadePath": "public-rust/gameplay-module-conformance",
      "sourceOfTruth": "engine-rs/crates/rules/rule-project-bundle",
      "intendedConsumerRole": "Public statically linked build, ProjectBundle bootstrap, invocation, state, save/reload, playback, and verification-replay conformance runner for downstream gameplay modules.",
      "allowedConsumerRoles": [
        "asha-demo",
        "asha-testing",
        "asha-rulebench"
      ],
      "dependencyForm": {
        "kind": "git",
        "versionRequirement": "^0.1",
        "example": "asha-gameplay-module-conformance = { git = \"https://github.com/FuzzySlipper/asha-engine.git\", rev = \"<40-char-commit>\", version = \"^0.1\" }",
        "developmentExample": "asha-gameplay-module-conformance = { path = \"../asha-engine/public-rust/gameplay-module-conformance\" }"
      },
      "exposes": [
        "GameplayModuleConformanceCase",
        "GameplayModuleConformanceCheck",
        "GameplayModuleConformanceDeclaredRead",
        "GameplayModuleConformanceGap",
        "GameplayModuleConformanceProject",
        "GameplayModuleConformanceReport",
        "run_gameplay_module_conformance"
      ],
      "requiredExposes": [
        "GameplayModuleConformanceCase",
        "GameplayModuleConformanceReport",
        "run_gameplay_module_conformance"
      ],
      "changelog": "docs/consumer-compatibility.md#rust-gameplay-module-conformance-compatibility-log"
    },
    {
      "crate": "asha-gameplay-module-sdk",
      "status": "public",
      "disposition": "preferred",
      "facadePath": "public-rust/gameplay-module-sdk",
      "sourceOfTruth": "engine-rs/crates/rules/gameplay-module-sdk",
      "intendedConsumerRole": "Public Rust authoring, declared-read, state, and static-composition facade for downstream ASHA gameplay modules.",
      "allowedConsumerRoles": [
        "asha-demo",
        "asha-testing",
        "asha-rulebench"
      ],
      "dependencyForm": {
        "kind": "git",
        "versionRequirement": "^0.1",
        "example": "asha-gameplay-module-sdk = { git = \"https://github.com/FuzzySlipper/asha-engine.git\", rev = \"<40-char-commit>\", version = \"^0.1\" }",
        "developmentExample": "asha-gameplay-module-sdk = { path = \"../asha-engine/public-rust/gameplay-module-sdk\" }"
      },
      "exposes": [
        "GameplayModuleBehavior",
        "GameplayModuleContext",
        "GameplayModuleActions",
        "GameplayStaticModuleProvider",
        "GameplayStaticCompositionBuilder",
        "GameplayContractRef",
        "GameplayEventEnvelope",
        "GameplayReadPlan",
        "GameplayReadRequest",
        "GameplayReadViewRequirement",
        "GameplayFrozenRead",
        "GameplayOwnerQuery",
        "GameplayModuleBindingRegistryBuilder",
        "GameplayModuleBindingTarget",
        "GameplayModuleConfiguration",
        "GameplayModuleFact",
        "GameplayTypedModuleStateAdapter",
        "StandardGameplayEventKind",
        "TriggerOverlapGameplayPayload",
        "TypedGameplayEventCodec"
      ],
      "requiredExposes": [
        "GameplayModuleBehavior",
        "GameplayModuleActions",
        "GameplayStaticModuleProvider"
      ],
      "changelog": "docs/consumer-compatibility.md#rust-gameplay-module-sdk-compatibility-log"
    },
    {
      "crate": "asha-gameplay-runtime-host",
      "status": "public",
      "disposition": "quarantined",
      "compatibilityEntry": "standalone-gameplay-runtime-host",
      "facadePath": "public-rust/gameplay-runtime-host",
      "sourceOfTruth": "engine-rs/crates/rules/gameplay-runtime-host",
      "intendedConsumerRole": "Public Rust host seam for statically composed gameplay modules, ProjectBundle bindings, validated prefab bootstrap/placement, trigger reconciliation, pre-commit decisions, actor pose binding, snapshots, and bounded readouts.",
      "allowedConsumerRoles": [
        "asha-demo",
        "asha-testing",
        "asha-rulebench"
      ],
      "dependencyForm": {
        "kind": "git",
        "versionRequirement": "^0.1",
        "example": "asha-gameplay-runtime-host = { git = \"https://github.com/FuzzySlipper/asha-engine.git\", rev = \"<40-char-commit>\", version = \"^0.1\" }",
        "developmentExample": "asha-gameplay-runtime-host = { path = \"../asha-engine/public-rust/gameplay-runtime-host\" }"
      },
      "exposes": [
        "GameplayRuntimeHost",
        "GAMEPLAY_RUNTIME_HOST_COMPATIBILITY_DIAGNOSTIC",
        "GameplayRuntimeHostError",
        "GameplayRuntimeHostInput",
        "GameplayRuntimeProjectInput",
        "GameplayRuntimeSpatialEntity",
        "GameplayRuntimeDeclaredReadPlan",
        "GameplayRuntimeDecisionOwner",
        "GameplayRuntimeDecisionOwnerOutput",
        "GameplayDecisionMoment",
        "GameplayDecisionReceipt",
        "GameplayDecisionStatus",
        "GameplayOperationWorkspace",
        "GameplayRuntimeMovementReceipt",
        "GameplayTriggerDefinition",
        "GameplayRuntimeHostReadout",
        "GameplayRuntimePrefabBootstrap",
        "GameplayRuntimePrefabReadout",
        "GameplayRuntimeSchedulerCommandReceipt",
        "GameplayRuntimeSchedulerDefinition",
        "GameplayRuntimeSchedulerReadout",
        "GameplayRuntimeSchedulerRoutingReceipt",
        "GameplaySchedulerCommand",
        "ScheduledActionId",
        "ScheduledActionValidity",
        "TickScheduledActionDraft"
      ],
      "requiredExposes": [
        "GameplayRuntimeHost",
        "GameplayRuntimeHostInput",
        "GameplayRuntimeProjectInput",
        "GameplayRuntimeDecisionOwner",
        "GameplayDecisionReceipt",
        "GameplayRuntimeHostReadout",
        "GameplayRuntimeSchedulerDefinition",
        "GameplayRuntimeSchedulerReadout",
        "GameplaySchedulerCommand"
      ],
      "changelog": "docs/consumer-compatibility.md#rust-gameplay-runtime-host-compatibility-log"
    },
    {
      "crate": "asha-runtime-session-composition",
      "status": "public",
      "disposition": "preferred",
      "facadePath": "public-rust/runtime-session-composition",
      "sourceOfTruth": "engine-rs/crates/bridge/runtime-bridge-api",
      "intendedConsumerRole": "Public builder for one native RuntimeSession authority cell containing the bounded RuntimeBridge root and statically linked gameplay modules.",
      "allowedConsumerRoles": [
        "asha-demo",
        "asha-testing",
        "asha-rulebench"
      ],
      "dependencyForm": {
        "kind": "git",
        "versionRequirement": "^0.1",
        "example": "asha-runtime-session-composition = { git = \"https://github.com/FuzzySlipper/asha-engine.git\", rev = \"<40-char-commit>\", version = \"^0.1\" }",
        "developmentExample": "asha-runtime-session-composition = { path = \"../asha-engine/public-rust/runtime-session-composition\" }"
      },
      "exposes": [
        "StaticRuntimeSessionBuilder",
        "StaticRuntimeSessionCompositionError",
        "ComposedRuntimeSessionCheckpoint",
        "ComposedRuntimeSessionReadout",
        "EngineBridge",
        "GameplayRuntimeProjectInput",
        "RuntimeBridge",
        "Vec3"
      ],
      "requiredExposes": [
        "StaticRuntimeSessionBuilder",
        "ComposedRuntimeSessionCheckpoint",
        "ComposedRuntimeSessionReadout",
        "RuntimeBridge"
      ],
      "changelog": "docs/consumer-compatibility.md#rust-runtime-session-composition-compatibility-log"
    },
    {
      "crate": "asha-native-runtime-provider",
      "status": "public",
      "disposition": "preferred",
      "facadePath": "public-rust/native-runtime-provider",
      "sourceOfTruth": "engine-rs/crates/bridge/native-bridge",
      "intendedConsumerRole": "Links one downstream static RuntimeSession composition into the generated N-API operation table without copying transport verbs.",
      "allowedConsumerRoles": [
        "asha-demo",
        "asha-testing",
        "asha-rulebench"
      ],
      "dependencyForm": {
        "kind": "git",
        "versionRequirement": "^0.1",
        "example": "asha-native-runtime-provider = { git = \"https://github.com/FuzzySlipper/asha-engine.git\", rev = \"<40-char-commit>\", version = \"^0.1\" }",
        "developmentExample": "asha-native-runtime-provider = { path = \"../asha-engine/public-rust/native-runtime-provider\" }"
      },
      "exposes": [
        "install_native_engine_bridge_factory",
        "native_provider_module_init",
        "NativeEngineBridgeFactory"
      ],
      "requiredExposes": [
        "install_native_engine_bridge_factory",
        "native_provider_module_init"
      ],
      "changelog": "docs/consumer-compatibility.md#rust-native-runtime-provider-compatibility-log"
    }
  ]
}
