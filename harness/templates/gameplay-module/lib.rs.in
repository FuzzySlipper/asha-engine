use asha_gameplay_module_sdk::*;
use serde::{Deserialize, Serialize};

#[derive(Debug, Serialize, Deserialize)]
pub struct Input {
    pub amount: u64,
}

pub struct __TYPE_NAME__Behavior;

impl GameplayModuleBehavior for __TYPE_NAME__Behavior {
    fn invoke(
        &self,
        context: &GameplayModuleContext<'_>,
    ) -> Result<GameplayModuleActions, GameplayModuleError> {
        let input: Input = context.event_payload()?;
        let mut actions = context.actions();
        actions.trace(format!("__MODULE_ID__.observed:{}", input.amount));
        Ok(actions)
    }
}

pub fn module_id() -> &'static str {
    "__MODULE_ID__"
}

fn input_schema_descriptor() -> &'static str {
    "__MODULE_ID__.input{amount:u64};canonical-json-v1"
}

fn input_contract() -> GameplayContractRef {
    gameplay_contract(
        "__MODULE_ID__",
        "input",
        1,
        input_schema_descriptor(),
    )
}

fn input_codec() -> TypedGameplayEventCodec<Input> {
    gameplay_serde_json_codec(input_contract(), input_schema_descriptor())
}

fn topology() -> GameplayDerivedModuleTopology {
    let invocation = GameplayModuleInvocationTopology::observe(
        "__MODULE_ID__.observe",
        "__MODULE_ID__.observe",
        input_contract(),
        input_contract(),
        GameplayHeaderSelector {
            source: None,
            target: None,
            scope: None,
            required_tags: Vec::new(),
        },
        8,
        1,
        1_024,
    );
    GameplayDerivedModuleTopology::derive(module_id(), vec![invocation])
        .expect("generated topology is unambiguous")
}

fn build_provenance() -> GameplayModuleBuildProvenance {
    GameplayModuleBuildProvenance::from_build_inputs(
        env!("CARGO_PKG_NAME"),
        env!("CARGO_PKG_VERSION"),
        &[include_bytes!("lib.rs")],
        include_bytes!("../Cargo.lock"),
        &[],
    )
}

pub fn manifest() -> GameplayModuleManifest {
    let topology = topology();
    let mut manifest = GameplayModuleManifest {
        module_ref: GameplayModuleRef {
            module_id: module_id().to_owned(),
            namespace: "__MODULE_ID__".to_owned(),
            version: "0.1.0".to_owned(),
            sdk_hash: String::new(),
            contract_hash: String::new(),
            artifact_hash: String::new(),
            provider_id: "provider.__MODULE_ID__".to_owned(),
        },
        published_events: vec![input_codec().declaration().clone()],
        subscriptions: vec![],
        invocations: vec![],
        read_views: vec![],
        proposal_kinds: vec![],
        state_schemas: vec![],
        fact_schemas: vec![],
        ordering: vec![],
        budget: GameplayExecutionBudget {
            max_waves: 4,
            max_events_per_root: 32,
            max_proposals_per_root: 16,
            max_invocations_per_root: 32,
            max_payload_bytes_per_root: 65_536,
        },
        deterministic_requirements: vec!["canonical-json".to_owned()],
        source_hash: String::new(),
    };
    topology
        .apply_to_manifest(&mut manifest)
        .expect("generated topology belongs to its manifest");
    build_provenance().apply_to_manifest::<__TYPE_NAME__Behavior>(&mut manifest);
    manifest
}

pub fn provider() -> GameplayStaticModuleProvider {
    let topology = topology();
    GameplayStaticModuleProvider::linked_from_manifest(
        manifest(),
        &build_provenance(),
        __TYPE_NAME__Behavior,
    )
    .event_codec(GameplayEventCodecRegistration::typed(input_codec()))
    .derived_topology(&topology)
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn generated_provider_composes() {
        let mut builder = GameplayStaticCompositionBuilder::new();
        builder.add_provider(provider());
        builder.build().expect("generated provider composes");
    }
}
