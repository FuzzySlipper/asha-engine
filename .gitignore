# ── Rust ────────────────────────────────────────────────────────────────────────
target/
engine-rs/target/
public-rust/*/target/
public-rust/*/Cargo.lock
**/*.rs.bk

# ── Node / TypeScript ──────────────────────────────────────────────────────────
node_modules/
ts/node_modules/
ts/packages/*/node_modules/
**/*.tsbuildinfo
coverage/
.nyc_output/
.vite/
.parcel-cache/
.pnpm-store/
.turbo/
dist/
__pycache__/
*.pyc
*.pyo
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Native/compiler outputs are rebuilt by their owning gate and are never source.
*.node
*.so
*.dylib
*.dll
*.o
*.obj
*.a
*.rlib
*.rmeta

# ── Generated smoke-harness artifacts ───────────────────────────────────────────
harness/smoke-out/
harness/shell-out/
harness/perf-out/
ts/artifacts/

# ── Root session artifacts ─────────────────────────────────────────────────────
# Ad-hoc Studio/Agora sessions must write durable evidence under harness/ or the
# owning repo, not as committed root logs/pids/capture JSON.
/asha-studio-*-dev*.log
/asha-studio-*-dev*.pid
/asha-studio-*-agora-*.json

# ── IDE / editor ────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.orig

# ── OS junk ─────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Environment / secrets ───────────────────────────────────────────────────────
.env
.env.*
!.env.example
