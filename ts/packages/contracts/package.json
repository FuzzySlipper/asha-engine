{
  "name": "@asha/contracts",
  "version": "0.1.0",
  "private": true,
  "asha": {
    "publicSurface": {
      "tier": 1,
      "role": "generated-contracts",
      "allowedConsumers": ["asha-testing", "asha-demo", "asha-studio", "downstream-authoring"],
      "rootExportOnly": true,
      "nativeTransportAccess": false,
      "source": "engine-rs/crates/protocol/* via protocol-codegen"
    },
    "compatibility": {
      "version": "contracts.v0",
      "metadataFile": "compatibility.json",
      "changelog": "docs/consumer-compatibility.md#generated-contract-compatibility-log"
    }
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types":  "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build":     "tsc --build",
    "typecheck": "tsc --noEmit",
    "test":      "tsc --noEmit"
  }
}
