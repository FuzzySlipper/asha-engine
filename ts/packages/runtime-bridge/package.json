{
  "name": "@asha/runtime-bridge",
  "version": "0.1.0",
  "private": true,
  "asha": {
    "publicSurface": {
      "tier": 1,
      "role": "runtime-transport",
      "allowedConsumers": ["asha-testing", "asha-demo", "asha-studio", "downstream-authoring"],
      "rootExportOnly": true,
      "allowedExportSubpaths": ["./reference"],
      "referenceSubpathPolicy": {
        "./reference": {
          "classification": "fixture-reference",
          "productAuthority": false,
          "allowedUse": ["tests", "compatibility-fixtures", "offline-smoke"],
          "disallowedUse": ["product-authority", "live-demo-default", "studio-live-attach"]
        }
      },
      "nativeTransportAccess": true,
      "nativeTransportRule": "@asha/runtime-bridge is the only public package allowed to import @asha/native-bridge; consumers must not import raw transports directly."
    },
    "compatibility": {
      "version": "runtime-bridge.v0",
      "metadataFile": "compatibility.json",
      "changelog": "docs/consumer-compatibility.md#runtime-bridge-compatibility-log"
    }
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/browser.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./reference": {
      "types": "./dist/reference.d.ts",
      "browser": "./dist/reference-browser.js",
      "import": "./dist/reference.js",
      "default": "./dist/reference.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --build",
    "test": "tsc --build && node --test 'dist/**/*.test.js'",
    "test:evidence:reference": "tsc --build && node --test --test-name-pattern '\\[reference evidence\\]' dist/runtime-session-evidence.test.js",
    "test:evidence:rust": "tsc --build && node --test --test-name-pattern '\\[rust authority evidence\\]' dist/runtime-session-evidence.test.js dist/native-fail-closed.test.js"
  },
  "dependencies": {
    "@asha/contracts": "workspace:*",
    "@asha/native-bridge": "workspace:*",
    "@asha/runtime-session": "workspace:*"
  }
}
