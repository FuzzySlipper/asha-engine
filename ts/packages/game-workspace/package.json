{
  "name": "@asha/game-workspace",
  "version": "0.1.0",
  "asha": {
    "publicSurface": {
      "tier": 1,
      "role": "downstream-authoring-workspace",
      "allowedConsumers": ["asha-testing", "asha-demo", "asha-studio", "downstream-authoring"],
      "rootExportOnly": true,
      "nativeTransportAccess": false
    }
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --build",
    "test": "tsc --build && node --test 'dist/**/*.test.js'"
  },
  "dependencies": {
    "@asha/contracts": "workspace:*"
  },
  "compatibility": {
    "surface": "@asha/game-workspace",
    "metadataFile": "compatibility.json",
    "changelog": "docs/consumer-compatibility.md#game-workspace-compatibility-log"
  }
}
